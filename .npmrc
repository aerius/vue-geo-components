# Publish the @aerius scope to Aerius Nexus. Confirm the exact hosted-npm repo
# path with infra before the first release; a group/proxy repo is read-only.
@aerius:registry=https://nexus.aerius.nl/repository/npm-hosted/

# Basic auth from the org's NEXUS_USERNAME / NEXUS_PASSWORD secrets. CI sets
# NEXUS_AUTH to base64("user:password") before `npm publish`
# (see .github/workflows/on-release-published.yml).
//nexus.aerius.nl/repository/npm-hosted/:_auth=${NEXUS_AUTH}
always-auth=true
