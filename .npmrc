# Fetch the @aerius scope from Aerius Nexus. Confirm the exact hosted-npm repo
# path with infra before the first release.
@aerius:registry=https://nexus.aerius.nl/repository/npm-hosted/

# Auth uses a single token, not a personal login. CI sets NEXUS_TOKEN from a
# repository secret (a token for a dedicated Nexus CI account). Publishing only
# runs on the upstream repo (aerius/vue-geo-components).
//nexus.aerius.nl/repository/npm-hosted/:_authToken=${NEXUS_TOKEN}
